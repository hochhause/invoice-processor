# Invoice Processor — desktop settings
# This file lives in your app-data folder and is loaded on every start:
#   Windows:  %APPDATA%\InvoiceProcessor\settings.env
#   macOS:    ~/Library/Application Support/InvoiceProcessor/settings.env
#
# The Anthropic API key is normally set once via the web UI on first launch
# (it is appended to this file). Everything below mirrors the server .env.

# ── LLM ──────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...        # set via the first-run screen
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MODEL_TEXT=claude-haiku-4-5-20251001

# ── Debtor + per-account config (pain.001 export) ────────────────────────
DEBTOR_NAME=Lyfegen HealthTech AG

# BKB: CHF domestic + SEPA (SEK/EUR fall back to the CHF account)
BKB_CURRENCIES=CHF,EUR,SEK
BKB_DEFAULT_CCY=CHF
BKB_CHF_IBAN=
BKB_CHF_BIC=BLKBCH22
BKB_EUR_IBAN=
BKB_EUR_BIC=BLKBCH22

# Raiffeisen: cross-border (CAD/GBP fall back to the USD account)
RAIFFEISEN_CURRENCIES=USD,CAD,GBP
RAIFFEISEN_DEFAULT_CCY=USD
RAIFFEISEN_USD_IBAN=
RAIFFEISEN_USD_BIC=RAIFCH22XXX
RAIFFEISEN_CAD_IBAN=
RAIFFEISEN_CAD_BIC=RAIFCH22XXX
RAIFFEISEN_GBP_IBAN=
RAIFFEISEN_GBP_BIC=RAIFCH22XXX

# ── Optional ─────────────────────────────────────────────────────────────
# APP_PASSWORD=          # leave empty on a personal machine (localhost only)
# DEV_MODE=false
