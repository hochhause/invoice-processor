# Tier 1 LLM Fallback: Text-based field extraction when regex fails
# Only enables "Retry with AI" button if API key is valid
ANTHROPIC_API_KEY=sk-ant-...
ENABLE_LLM_FALLBACK=true

# CSV bank rule set (filename without .py in /app/rules/)
CSV_RULE_SET=default

# DEV mode: auto-fill missing due_date, relax reference requirement
DEV_MODE=true

# DEBUG: Store extracted markdown files for inspection (path on host/container)
# Leave empty to disable (default)
# DEBUG_MD_DIR=/app/data/debug-md

# DEBUG: Save QR scan images (full page + bottom crop, each DPI) as PNGs
# Filenames: <job_id>_p<page>_<dpi>dpi_full.png / _crop.png
# Leave empty to disable (default)
# DEBUG_QR_DIR=/app/data/debug-qr

# ISO 20022 pain.001 Debtor (sender) — required for /download/xml endpoint
DEBTOR_NAME=My Company AG
DEBTOR_IBAN=CH...
DEBTOR_BIC=XXXXCHXX
