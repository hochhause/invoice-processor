# ── LLM (Anthropic Claude) ───────────────────────────────────────────────────
# API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model ID — claude-haiku-4-5-20251001 is the default (fast, cheap)
LLM_MODEL=claude-haiku-4-5-20251001

# ── Debtor (sender) for ISO 20022 pain.001 XML export ───────────────────────
DEBTOR_NAME=My Company AG
DEBTOR_IBAN=CH0000000000000000000
DEBTOR_BIC=XXXXCHXX

# ── Dev mode ─────────────────────────────────────────────────────────────────
# true: auto-fill missing due_date, relax reference validation
DEV_MODE=true
