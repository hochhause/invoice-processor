# -- LLM ----------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# image stage; set LLM_MODEL=claude-sonnet-4-6 to switch to Sonnet
LLM_MODEL=claude-haiku-4-5-20251001
# text stage (keep in sync with LLM_MODEL)
LLM_MODEL_TEXT=claude-haiku-4-5-20251001
# Use Batch API for overnight processing (50% cost saving, ~1h latency)
LLM_USE_BATCH=false

# -- Auth (optional - for secure deployment) ----------------------------------
# Set APP_PASSWORD to enable HTTP Basic auth on every page + API route.
# Leave empty or unset to disable auth entirely.
APP_PASSWORD=
# optional, defaults to "admin"
APP_USERNAME=admin

# -- Debtor + per-account config (pain.001) -----------------------------------
# Per-bank, per-currency accounts. bank = bank whose *_CURRENCIES holds the ccy;
# acct = {BANK}_{CCY}_* if present, else {BANK}_{DEFAULT_CCY}_* (FX fallback).
DEBTOR_NAME=Lyfegen HealthTech AG

# BKB: CHF domestic + SEPA (SEK/EUR -- SEK falls back to the CHF account)
BKB_CURRENCIES=CHF,EUR,SEK
BKB_DEFAULT_CCY=CHF
BKB_CHF_IBAN=<CH IBAN>
BKB_CHF_BIC=BLKBCH22
BKB_EUR_IBAN=<CH IBAN>
BKB_EUR_BIC=BLKBCH22

# Raiffeisen: cross-border (CAD/GBP fall back to the USD account)
RAIFFEISEN_CURRENCIES=USD,CAD,GBP
RAIFFEISEN_DEFAULT_CCY=USD
RAIFFEISEN_USD_IBAN=<CH IBAN>
RAIFFEISEN_USD_BIC=RAIFCH22XXX
RAIFFEISEN_CAD_IBAN=<CH IBAN>
RAIFFEISEN_CAD_BIC=RAIFCH22XXX
RAIFFEISEN_GBP_IBAN=<CH IBAN>
RAIFFEISEN_GBP_BIC=RAIFCH22XXX

# -- Paths --------------------------------------------------------------------
UPLOAD_DIR=/app/data/uploads
DB_PATH=/app/data/invoices.db
# optional: save QR scan debug images
DEBUG_QR_DIR=/app/data/debug_qr

# -- Feature flags ------------------------------------------------------------
DEV_MODE=true
