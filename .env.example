# LLM fallback (for scanned/handwritten PDFs mdx cannot read)
# Provider: ollama | claude | deepseek
LLM_PROVIDER=ollama
# LLM_URL options (Ollama must be started with OLLAMA_HOST=0.0.0.0:11434):
#   - http://172.29.208.1:11434         (WSL vEthernet - Podman on Windows, default)
#   - http://host.docker.internal:11434 (Docker Desktop on Windows/Mac)
#   - http://127.0.0.1:11434            (localhost - only if app runs on host)
LLM_URL=http://172.29.208.1:11434
LLM_MODEL=llama3.2

# For claude (haiku etc.) set provider=claude and add key:
# LLM_PROVIDER=claude
# LLM_URL=https://api.anthropic.com
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# For deepseek:
# LLM_PROVIDER=deepseek
# LLM_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=...

# CSV bank rule set (filename without .py in /app/rules/)
CSV_RULE_SET=default

# OCR fallback threshold: if mdx output < N chars, use LLM fallback
MDX_MIN_CHARS=80

# DEV mode: auto-fill missing due_date, relax reference requirement
DEV_MODE=true

# DEBUG: Store extracted markdown files for inspection (path on host/container)
# Leave empty to disable (default)
# DEBUG_MD_DIR=/app/data/debug-md
